{
	"name": "autosave-control",
	"version": "0.0.12",
	"description": "Delay autosave until editing has stopped for a chosen number of seconds.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"wdio": "wdio run ./wdio.conf.mts",
		"wdio:quit-save": "node ./scripts/verify-quit-save.mjs",
		"wdio:all": "npm run wdio && npm run wdio:quit-save"
	},
	"keywords": [
		"save",
		"frequency",
		"file",
		"autosave",
		"interval",
		"period",
		"time"
	],
	"author": "Miha Smrekar",
	"license": "MIT",
	"devDependencies": {
		"@types/mocha": "^10.0.10",
		"@types/node": "^16.18.126",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"@wdio/cli": "^9.27.0",
		"@wdio/globals": "^9.27.0",
		"@wdio/local-runner": "^9.27.0",
		"@wdio/mocha-framework": "^9.27.0",
		"@wdio/spec-reporter": "^9.27.0",
		"builtin-modules": "3.3.0",
		"esbuild": "0.17.3",
		"expect-webdriverio": "^5.6.5",
		"mocha": "^11.7.5",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"tsx": "^4.21.0",
		"typescript": "4.7.4",
		"wdio-obsidian-reporter": "^3.0.2",
		"wdio-obsidian-service": "^3.0.2"
	},
	"dependencies": {
		"watch": "^1.0.2"
	}
}
